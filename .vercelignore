# Vercel Ignore File
# Exclude files and directories that shouldn't be deployed

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Local development
.env
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# Legacy and test files
legacy_app/
tests/
test_*.py
check_*.py
debug_*.py
unlock_account.py

# Documentation
*.md
!README.md

# Data directory (database will be in /tmp in serverless)
data/

# Build artifacts
dist/
build/
*.egg-info/