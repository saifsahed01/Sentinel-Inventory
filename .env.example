# Database Configuration
# Path to the SQLite database file (relative to project root)
# Use forward slashes (/) or relative paths - automatically converted to OS-specific format
# Works on both Windows and Linux
DATABASE_PATH=data/inventory.db

# Authentication Configuration
# Session timeout in minutes (how long users stay logged in)
SESSION_TIMEOUT_MINUTES=30

# Maximum number of failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5

# Number of bcrypt hashing rounds for password security (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Validation Configuration
# Maximum length for product names
MAX_PRODUCT_NAME_LENGTH=100

# Maximum length for usernames
MAX_USERNAME_LENGTH=50

# Minimum length for usernames
MIN_USERNAME_LENGTH=3

# Minimum length for passwords
MIN_PASSWORD_LENGTH=8

# Maximum quantity allowed for inventory items
MAX_QUANTITY=1000000

# Maximum price allowed for inventory items
MAX_PRICE=1000000.00

# Business Rules
# Threshold for low stock warnings
LOW_STOCK_THRESHOLD=5

# Logging Configuration
# Directory where log files will be stored
LOG_DIRECTORY=logs

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Application Configuration
# Name of the application
APP_NAME=Inventory Management System

# Current version of the application
APP_VERSION=2.0.0

# Enable/disable debug mode (set to False in production!)
DEBUG_MODE=False

# Flask Configuration
# Secret key for Flask session management and CSRF protection
# IMPORTANT: Generate a strong random key for production using:
# python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secret-key-in-production